#!/bin/sh
# moonlight-commit commit-msg hook enforcing override during block window with day filtering and whitelist

usage() {
  echo "Usage: commit-msg <commit-msg-file>" >&2
}

if [ "$#" -ne 1 ]; then
  usage
  exit 2
fi

if [ ! -f "$1" ]; then
  echo "commit-msg file must exist: $1" >&2
  exit 2
fi

# Load configuration with defaults. Environment variables override git config.
BLOCK_START="${MOONLIGHT_BLOCK_START:-$(git config --get moonlight-commit.blockStart 2>/dev/null)}"
[ -z "$BLOCK_START" ] && BLOCK_START=9
BLOCK_END="${MOONLIGHT_BLOCK_END:-$(git config --get moonlight-commit.blockEnd 2>/dev/null)}"
[ -z "$BLOCK_END" ] && BLOCK_END=17
BLOCK_DAYS="${MOONLIGHT_BLOCK_DAYS:-$(git config --get moonlight-commit.blockDays 2>/dev/null)}"
[ -z "$BLOCK_DAYS" ] && BLOCK_DAYS="1,2,3,4,5"
WHITELIST_ORGS="${MOONLIGHT_WHITELIST_ORGS:-$(git config --get moonlight-commit.whitelistOrgs 2>/dev/null)}"

csv_contains() {
  needle="$1"
  haystack="$2"
  old_ifs=$IFS
  IFS=,
  for item in $haystack; do
    IFS=$old_ifs
    item=$(printf '%s' "$item" | sed 's/^[[:space:]]*//;s/[[:space:]]*$//')
    if [ "$item" = "$needle" ]; then
      return 0
    fi
    IFS=,
  done
  IFS=$old_ifs
  return 1
}

lowercase() {
  printf '%s' "$1" | tr '[:upper:]' '[:lower:]'
}

csv_contains_casefold() {
  needle=$(lowercase "$1")
  haystack="$2"
  old_ifs=$IFS
  IFS=,
  for item in $haystack; do
    IFS=$old_ifs
    item=$(printf '%s' "$item" | sed 's/^[[:space:]]*//;s/[[:space:]]*$//')
    if [ "$(lowercase "$item")" = "$needle" ]; then
      return 0
    fi
    IFS=,
  done
  IFS=$old_ifs
  return 1
}

branch_has_bypass_label() {
  branch=$(lowercase "$1")
  old_ifs=$IFS
  IFS=/
  for segment in $branch; do
    IFS=$old_ifs
    case "$segment" in
      hotfix|vacation)
        IFS=$old_ifs
        return 0
        ;;
    esac
    IFS=/
  done
  IFS=$old_ifs
  return 1
}

is_integer() {
  case "$1" in
    ""|*[!0-9]*)
      return 1
      ;;
  esac
  return 0
}

is_valid_org_name() {
  [ "${#1}" -le 39 ] || return 1
  case "$1" in
    ""|-*|*-|*[!A-Za-z0-9-]*)
      return 1
      ;;
  esac
  return 0
}

is_valid_repo_name() {
  [ "${#1}" -le 100 ] || return 1
  case "$1" in
    ""|"."|".."|*/*|*\\*|*[!A-Za-z0-9._-]*)
      return 1
      ;;
  esac
  return 0
}

is_blocked_hour() {
  current_hour="$1"
  current_day="$2"

  if [ "$BLOCK_START" -lt "$BLOCK_END" ]; then
    csv_contains "$current_day" "$BLOCK_DAYS" || return 1
    [ "$current_hour" -ge "$BLOCK_START" ] && [ "$current_hour" -lt "$BLOCK_END" ]
    return $?
  fi

  previous_day=$((current_day - 1))
  [ "$previous_day" -eq 0 ] && previous_day=7
  if [ "$current_hour" -ge "$BLOCK_START" ]; then
    csv_contains "$current_day" "$BLOCK_DAYS"
    return $?
  fi
  if [ "$current_hour" -lt "$BLOCK_END" ]; then
    csv_contains "$previous_day" "$BLOCK_DAYS"
    return $?
  fi
  return 1
}

github_org_from_origin() {
  origin="$1"
  origin_lower=$(lowercase "$origin")
  case "$origin_lower" in
    git@github.com:*)
      repo_path=${origin_lower#*:}
      ;;
    ssh://git@github.com:22/*)
      repo_path=${origin_lower#ssh://git@github.com:22/}
      ;;
    ssh://git@github.com/*)
      repo_path=${origin_lower#ssh://git@*/}
      ;;
    https://github.com/*)
      repo_path=${origin_lower#https://*/}
      ;;
    *)
      return 1
      ;;
  esac
  case "$repo_path" in
    */*)
      ;;
    *)
      return 1
      ;;
  esac
  org=${repo_path%%/*}
  repo=${repo_path#*/}
  repo=${repo%.git}
  if is_valid_org_name "$org" && is_valid_repo_name "$repo"; then
    printf '%s\n' "$org"
    return 0
  fi
  return 1
}

validate_config() {
  if ! is_integer "$BLOCK_START" || [ "$BLOCK_START" -lt 0 ] || [ "$BLOCK_START" -gt 23 ]; then
    echo "❌ moonlight-commit.blockStart must be an integer from 0 to 23" >&2
    exit 1
  fi
  if ! is_integer "$BLOCK_END" || [ "$BLOCK_END" -lt 1 ] || [ "$BLOCK_END" -gt 24 ]; then
    echo "❌ moonlight-commit.blockEnd must be an integer from 1 to 24" >&2
    exit 1
  fi
  if [ "$BLOCK_START" -eq "$BLOCK_END" ]; then
    echo "❌ moonlight-commit.blockStart must not equal blockEnd" >&2
    exit 1
  fi
  case "$BLOCK_DAYS" in
    *,,*|,*|*,)
      echo "❌ moonlight-commit.blockDays must not contain empty entries" >&2
      exit 1
      ;;
  esac
  old_ifs=$IFS
  IFS=,
  for day in $BLOCK_DAYS; do
    IFS=$old_ifs
    day=$(printf '%s' "$day" | sed 's/^[[:space:]]*//;s/[[:space:]]*$//')
    if ! is_integer "$day" || [ "$day" -lt 1 ] || [ "$day" -gt 7 ]; then
      echo "❌ moonlight-commit.blockDays must contain comma-separated integers from 1 to 7" >&2
      exit 1
    fi
    IFS=,
  done
  IFS=$old_ifs

  if [ -n "$WHITELIST_ORGS" ]; then
    case "$WHITELIST_ORGS" in
      *,,*|,*|*,)
        echo "❌ moonlight-commit.whitelistOrgs must not contain empty entries" >&2
        exit 1
        ;;
    esac
    old_ifs=$IFS
    IFS=,
    for org in $WHITELIST_ORGS; do
      IFS=$old_ifs
      org=$(printf '%s' "$org" | sed 's/^[[:space:]]*//;s/[[:space:]]*$//')
      if [ -z "$org" ]; then
        echo "❌ moonlight-commit.whitelistOrgs must not contain empty entries" >&2
        exit 1
      fi
      if ! is_valid_org_name "$org"; then
        echo "❌ moonlight-commit.whitelistOrgs entries must be GitHub org names" >&2
        exit 1
      fi
      IFS=,
    done
    IFS=$old_ifs
  fi
}

validate_config

# Get current local hour and day of week
CURRENT_HOUR=$(date +%H)
CURRENT_HOUR=${CURRENT_HOUR#0}
[ -z "$CURRENT_HOUR" ] && CURRENT_HOUR=0
CURRENT_DAY=$(date +%u)

# Get branch name and origin org
BRANCH_NAME=$(git rev-parse --abbrev-ref HEAD 2>/dev/null)
ORIGIN_URL=$(git remote get-url origin 2>/dev/null || echo "")
REPO_ORG=$(github_org_from_origin "$ORIGIN_URL" || echo "")

# Skip checks for explicit hotfix or vacation branch segments
branch_has_bypass_label "$BRANCH_NAME" && exit 0

# Skip checks for whitelisted orgs
if csv_contains_casefold "$REPO_ORG" "$WHITELIST_ORGS"; then
  exit 0
fi

# If within blocked hours, enforce [override] keyword
if is_blocked_hour "$CURRENT_HOUR" "$CURRENT_DAY"; then
  COMMIT_MSG_FILE="$1"
  if ! grep -q "\[override\]" "$COMMIT_MSG_FILE"; then
    FIRST_LINE=$(head -n1 "$COMMIT_MSG_FILE")
    echo "❌ Commit message '$FIRST_LINE' blocked between ${BLOCK_START}:00 and ${BLOCK_END}:00 on weekdays without [override]." >&2
    exit 1
  fi
fi

exit 0
